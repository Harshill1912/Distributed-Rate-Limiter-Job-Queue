# Copy to .env and adjust. All values have sane defaults in code.

# --- Redis ---
REDIS_HOST=localhost
REDIS_PORT=6379

# --- Postgres ---
DATABASE_URL=postgresql://admin:admin123@localhost:5432/jobqueue
POSTGRES_USER=admin
POSTGRES_PASSWORD=admin123
POSTGRES_DB=jobqueue

# --- Rate limiter (token bucket) ---
RATE_LIMIT_MAX_TOKENS=5         # burst size
RATE_LIMIT_REFILL_RATE=0.0833   # tokens per second (~1 every 12s)
RATE_LIMIT_KEY_TTL=3600

# --- Worker ---
MAX_RETRIES=3
BASE_BACKOFF_SECONDS=2
MAX_BACKOFF_SECONDS=60
SIMULATED_FAIL_RATE=0.3         # set 0 to disable simulated failures
LOG_LEVEL=INFO
